{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "debug-comm",
  "version": "0.1.1",
  "identifier": "debug-comm.laolaolulu.com",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1424",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "debug-comm",
        "width": 900,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDczMzI1MThGNTUyMDgzN0QKUldSOWd5QlZqMUV5Y3lPdURMQmZzRFVRM2dXem1qbjg1bHhIU0w3M1hFMThJOUxhUk9VVnBmYjMK",
      "endpoints": [
        "https://github.com/laolaolulu/debug-comm/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
